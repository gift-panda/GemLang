import gem.Util;

class List{
    #init(list, len){
        this.value = list;
        this.len = len;
    }

    init(list){
        if(!instanceOf(list, List)){
            throw IllegalArgumentError("A List must be passed.");
        }

        this.value = list.value;
        this.length = list.length;
    }

    length(){
        return this.len;
    }
}